// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id        String   @id @default(cuid())
  name      String   @unique
  role      String   @default("BENEFICIARY") // ADMIN or BENEFICIARY
  description String?
  folderName String   @unique
  isActive  Boolean  @default(true)
  deletedAt DateTime?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  expenses          Expense[]
  onboardingDocuments OnboardingDocument[]

  @@index([isActive])
}

model Expense {
  id        String   @id @default(cuid())
  beneficiaryId String
  beneficiary   User   @relation(fields: [beneficiaryId], references: [id])

  name      String
  description String?
  purchaseAmount Float
  refundAmount Float
  status    String   @default("NOWY") // NOWY, ZAAKCEPTOWANO, ODRZUCONO
  adminComment String?

  originalFileName String
  storedFileName   String
  filePath String
  mimeType String
  fileSize Int

  isDeleted Boolean @default(false)
  deletedAt DateTime?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([beneficiaryId])
  @@index([status])
  @@index([isDeleted])
}

model OnboardingDocument {
  id        String   @id @default(cuid())
  beneficiaryId String
  beneficiary   User   @relation(fields: [beneficiaryId], references: [id])

  title       String
  description String?
  originalFileName String
  storedFileName   String
  filePath String
  mimeType String
  fileSize Int

  uploadedByAdmin Boolean @default(true)
  isDeleted Boolean @default(false)
  deletedAt DateTime?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([beneficiaryId])
  @@index([isDeleted])
}
